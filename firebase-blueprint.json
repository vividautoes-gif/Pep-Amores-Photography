{
  "entities": {
    "Review": {
      "title": "Review",
      "description": "A user review or testimonial.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the reviewer."
        },
        "review": {
          "type": "string",
          "description": "The content of the review."
        },
        "createdAt": {
          "type": "timestamp",
          "description": "The time the review was created."
        },
        "isApproved": {
          "type": "boolean",
          "description": "Whether the review is approved for display."
        }
      },
      "required": ["name", "review", "createdAt", "isApproved"]
    }
  },
  "firestore": {
    "/reviews/{reviewId}": {
      "schema": {
        "$ref": "#/entities/Review"
      },
      "description": "Stores user reviews."
    }
  }
}
