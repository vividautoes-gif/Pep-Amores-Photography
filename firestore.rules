rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: photos
    // Fields:
    //   - title, title_en, title_ca: string
    //   - url: string (valid URL)
    //   - orientation: string (landscape, portrait, square)
    //   - country, location: string
    //   - year: number
    //   - tags: list of strings
    //   - isLFI: bool
    //   - lfiType: string
    //   - isFavorite: bool
    //   - favoriteScore: number
    //   - caption, caption_en, caption_ca: string
    //   - createdAt: timestamp
    //   - authorUid: string
    //
    // Collection: users
    // Fields:
    //   - email: string
    //   - role: string (admin, editor)
    //   - displayName: string
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "eduard.kun115@gmail.com" && request.auth.token.email_verified == true)
      );
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidPhoto(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.url is string && data.url.matches("^https://.*") &&
             data.orientation in ['landscape', 'portrait', 'square'] &&
             data.country is string &&
             data.year is number &&
             data.tags is list &&
             data.authorUid == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isOwner(userId);
    }

    match /photos/{photoId} {
      allow read: if true; // Public gallery
      allow create: if isAuthenticated() && isValidPhoto(request.resource.data);
      allow update: if isAuthenticated() && isValidPhoto(request.resource.data) && (isAdmin() || resource.data.authorUid == request.auth.uid);
      allow delete: if isAuthenticated() && (isAdmin() || resource.data.authorUid == request.auth.uid);
    }
  }
}
