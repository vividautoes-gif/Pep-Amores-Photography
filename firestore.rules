rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: photos
    // Fields:
    //   - title, title_en, title_ca: string
    //   - url: string (valid URL)
    //   - orientation: string (landscape, portrait, square)
    //   - country, location: string
    //   - year: number
    //   - tags: list of strings
    //   - isLFI: bool
    //   - lfiType: string
    //   - isFavorite: bool
    //   - favoriteScore: number
    //   - caption, caption_en, caption_ca: string
    //   - createdAt: timestamp
    //   - authorUid: string
    //
    // Collection: users
    // Fields:
    //   - email: string
    //   - role: string (admin, editor)
    //   - displayName: string
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/editors/$(request.auth.token.email)) ||
        (request.auth.token.email == "eduard.kun115@gmail.com" && request.auth.token.email_verified == true) ||
        (request.auth.token.email == "pep.amores@gmail.com" && request.auth.token.email_verified == true)
      );
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidPhoto(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.url is string && data.url.matches("^https://.*") &&
             data.orientation in ['landscape', 'portrait', 'square'] &&
             data.country is string &&
             data.year is number &&
             data.tags is list &&
             (!('cameraModel' in data) || data.cameraModel is string) &&
             (!('lens' in data) || data.lens is string) &&
             (!('focalLength' in data) || data.focalLength is string) &&
             (!('exposureTime' in data) || data.exposureTime is string) &&
             (!('aperture' in data) || data.aperture is string) &&
             (!('iso' in data) || data.iso is string) &&
             data.authorUid == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /editors/{email} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isOwner(userId);
    }

    match /photos/{photoId} {
      allow read: if true; // Public gallery
      allow create: if isAdmin() && isValidPhoto(request.resource.data);
      allow update: if isAdmin() && isValidPhoto(request.resource.data);
      allow delete: if isAdmin();
    }

    match /journeys/{journeyId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /stories/{storyId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if true; // Anyone can comment (moderated by default)
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
